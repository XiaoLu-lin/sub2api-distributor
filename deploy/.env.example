# =============================================================================
# sub2api-distributor Docker Environment Configuration
# =============================================================================
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# Start with:
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Host Bind Configuration
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
SERVER_PORT=8091

# -----------------------------------------------------------------------------
# Runtime Environment
# -----------------------------------------------------------------------------
APP_ENV=production
TZ=Asia/Shanghai
VITE_API_BASE_URL=/api
RUN_MIGRATIONS_ON_STARTUP=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Recommended: connect to the same PostgreSQL used by sub2api.
# Example when using an external host:
# DATABASE_DSN=postgres://sub2api:password@10.0.0.10:5432/sub2api?sslmode=disable
DATABASE_DSN=postgres://sub2api:change_this_password@host.docker.internal:5432/sub2api?sslmode=disable

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# IMPORTANT: use a fixed secret in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_this_distributor_jwt_secret

# -----------------------------------------------------------------------------
# Frontend Integration
# -----------------------------------------------------------------------------
# Main system registration base URL used to generate invite links.
VITE_MAIN_APP_BASE_URL=https://main.example.com

# Public distributor console origin(s), comma separated.
# Used by backend CORS validation for browser API calls.
CORS_ALLOWED_ORIGINS=https://distributor.example.com
